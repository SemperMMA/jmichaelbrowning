{
  "name": "jmichaelbrowning",
  "type": "module",
  "version": "4.0.0",
  "private": true,
  "description": "Personal site for J. Michael Browning \u2014 EmDash + Astro + Cloudflare D1/R2",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist",
    "deploy": "wrangler pages deploy ./dist",
    "bootstrap": "wrangler d1 execute jmb-db --local --file=./scripts/seed.sql && astro dev",
    "seed:remote": "wrangler d1 execute jmb-db --file=./scripts/seed.sql",
    "types": "emdash types",
    "typecheck": "astro check && tsc --noEmit",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "11.0.0",
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "astro": "5.0.0",
    "emdash": "0.7.0",
    "@emdash-cms/cloudflare": "0.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@cloudflare/workers-types": "^4.20250422.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.80.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
