---
// src/pages/index.astro
import Base from '../layouts/Base.astro';
import Atmosphere from '../components/Atmosphere.astro';
import { getEmDashCollection } from 'emdash';

// Fetch top 5 work items and top 4 writing items from D1
const { entries: workEntries } = await getEmDashCollection('work', {
  orderBy: [{ field: 'order', direction: 'asc' }],
  limit: 5,
  filter: { status: 'published' },
});

const { entries: writingEntries } = await getEmDashCollection('writing', {
  orderBy: [{ field: 'published_at', direction: 'desc' }],
  limit: 4,
  filter: { status: 'published' },
});
---
<Base>
  <!-- HERO -->
  <section class="hero grain" style="position: relative; overflow: hidden;" data-screen-label="01 Home — Hero">
    <Atmosphere />
    <div class="hero-content reveal-stagger" style="position: relative; z-index: 3; max-width: 1320px; margin: 0 auto; width: 100%; padding: 0 clamp(20px,4vw,56px);">
      <span class="eyebrow">J. Michael Browning · Portfolio / v.4</span>
      <h1 class="display-xl">
        Strategy, systems,<br />and <span class="glow">execution</span>
        <span style="color: var(--text-dim);">—</span><br />
        delivered with intent.
      </h1>
      <p class="lede" style="max-width: 58ch;">
        I translate complex missions into clear, measurable outcomes. A working archive of
        modernization, communications, and digital infrastructure for organizations that
        need to move with discipline and urgency.
      </p>
      <div class="flex gap-md mt-md" style="flex-wrap: wrap;">
        <a href="/work"  class="btn btn-primary">See the work →</a>
        <a href="/about" class="btn">About Michael</a>
      </div>
    </div>
    <div class="scroll-cue" aria-hidden="true" style="position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%); z-index: 3;">
      <span>Scroll</span>
      <span class="line"></span>
    </div>
  </section>

  <!-- PHILOSOPHY -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width: 1100px;">
        <span class="eyebrow">A working philosophy</span>
        <p class="display-lg" style="margin: 28px 0 0; line-height: 1.0; font-family: var(--display-font); letter-spacing: -0.04em;">
          I lead with discipline and urgency.<br />
          I cut through noise to <span class="accent-text">modernize the process</span>,
          strengthen trust, and deliver real impact
          <em style="font-style: normal; color: var(--text-mute);">where it matters</em>.
        </p>
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- SELECTED WORK -->
  <section class="section" data-screen-label="01 Home — Work">
    <div class="wrap">
      <div class="flex-between mb-md reveal" style="align-items: end;">
        <div>
          <span class="eyebrow">Selected work · 2018 → present</span>
          <h2 class="headline" style="margin-top: 18px; max-width: 22ch;">A short list of things I'm proud of.</h2>
        </div>
        <a href="/work" class="btn">All projects →</a>
      </div>
      <div class="reveal-stagger">
        {workEntries.length > 0 ? workEntries.map((p, i) => (
          <a class="work-row" href={`/work/${p.slug}`}>
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <span class="work-title">{p.data.title}</span>
            <span class="meta">{p.data.category}</span>
            <span class="meta">{p.data.year}</span>
            <span class="arrow">→</span>
          </a>
        )) : (
          <p class="text-mute" style="padding: 32px 0;">
            No projects yet — add them via the EmDash admin at <a href="/_emdash/admin">/_emdash/admin</a>.
          </p>
        )}
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- WRITING -->
  <section class="section" data-screen-label="01 Home — Writing">
    <div class="wrap">
      <div class="flex-between mb-md reveal" style="align-items: end;">
        <div>
          <span class="eyebrow">Writing · field notes</span>
          <h2 class="headline" style="margin-top: 18px;">Essays and dispatches from the work.</h2>
        </div>
        <a href="/writing" class="btn">All essays →</a>
      </div>
      <div class="grid-2 reveal-stagger">
        {writingEntries.length > 0 ? writingEntries.map(e => (
          <a href={`/writing/${e.slug}`} style="display: block; padding: 28px 0; border-bottom: 1px solid var(--hairline);">
            <span class="mono">
              {e.data.category} ·{' '}
              {e.data.published_at
                ? new Date(e.data.published_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
                : ''}
            </span>
            <h3 class="title" style="margin: 12px 0 10px;">{e.data.title}</h3>
            <p class="text-mute" style="margin: 0; font-size: 15px;">{e.data.summary}</p>
          </a>
        )) : (
          <p class="text-mute" style="padding: 32px 0; grid-column: 1 / -1;">
            No essays yet — add them via <a href="/_emdash/admin">/_emdash/admin</a>.
          </p>
        )}
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- CTA -->
  <section class="section-lg relative grain" data-screen-label="01 Home — CTA">
    <Atmosphere />
    <div class="wrap relative z-3 text-center">
      <div class="reveal" style="max-width: 28ch; margin: 0 auto;">
        <span class="eyebrow no-mark">Let's build something</span>
        <h2 class="display-lg" style="margin: 28px 0 28px;">
          If the mission is real, <br /><span class="accent-text">I want to hear about it.</span>
        </h2>
        <p class="lede" style="margin: 0 auto 36px; max-width: 56ch;">
          I take on a small number of engagements each year. Let's talk.
        </p>
        <div class="flex gap-md" style="justify-content: center; flex-wrap: wrap;">
          <a href="/contact" class="btn btn-primary">Start a conversation →</a>
          <a href="mailto:hello@jmichaelbrowning.com" class="btn">hello@jmichaelbrowning.com</a>
        </div>
      </div>
    </div>
  </section>
</Base>
