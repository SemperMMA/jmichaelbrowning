---
// src/pages/writing/[slug].astro
// SSR — fetched live from D1.
import Essay from '../../layouts/Essay.astro';
import { getEmDashEntry } from 'emdash';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/writing');

let entry;
try {
  entry = await getEmDashEntry('writing', slug);
} catch {
  return Astro.redirect('/writing');
}

if (!entry) return Astro.redirect('/404');

const {
  title, summary, category, published_at,
  reading_time, tags = [], body,
} = entry.data;
---
<Essay
  {title}
  {summary}
  {category}
  publishedAt={published_at}
  readingTime={reading_time}
  tags={Array.isArray(tags) ? tags : tags?.split(',').map((t: string) => t.trim())}
>
  <Fragment set:html={body ?? '<p>No content yet.</p>'} />
</Essay>
