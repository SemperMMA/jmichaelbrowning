---
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';

const writing = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));
---
<Page
  title="Things I'm trying to be useful about."
  eyebrow="Writing · field notes & essays"
  lede="The discipline of writing publicly is how I stay honest with myself about the work."
>
  <section class="section">
    <div class="wrap">
      <div class="reveal-stagger">
        {writing.map(e => (
          <a class="essay-card" href={`/writing/${e.slug}`}>
            <div>
              <span class="meta">{e.data.category} · {e.data.readingTime ? `${e.data.readingTime} min · ` : ''}{new Date(e.data.publishedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
              <h2 class="essay-title">{e.data.title}</h2>
              <p class="essay-excerpt">{e.data.summary}</p>
            </div>
            <div class="thumb"><div class="placeholder-stripes"></div></div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Page>
