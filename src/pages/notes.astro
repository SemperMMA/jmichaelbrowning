---
// src/pages/notes.astro
import Page from '../layouts/Page.astro';
import { getEmDashCollection } from 'emdash';

const { entries: notes } = await getEmDashCollection('notes', {
  orderBy: [{ field: 'number', direction: 'desc' }],
  filter: { status: 'published' },
});
---
<Page
  title="Working in the open."
  eyebrow="Notes · short, frequent, unpolished"
  lede="Short observations, drafts, things I'm chewing on. Not essays. Published as I think them."
>
  <section class="section" data-screen-label="07 Notes">
    <div class="wrap-narrow">
      <div class="reveal-stagger">
        {notes.length > 0 ? notes.map(n => (
          <article style="padding: 32px 0; border-bottom: 1px solid var(--hairline);">
            <span class="mono">
              № {String(n.data.number ?? '').padStart(3, '0')} ·{' '}
              {n.data.published_at
                ? new Date(n.data.published_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
                : ''}
            </span>
            <h3 class="title" style="margin: 14px 0 12px;">{n.data.title}</h3>
            <div class="text-mute" set:html={n.data.body ?? n.data.excerpt ?? ''} />
          </article>
        )) : (
          <p class="text-mute" style="padding: 48px 0;">
            No notes yet. Add them at <a href="/_emdash/admin">/_emdash/admin</a> → Notes.
          </p>
        )}
      </div>
    </div>
  </section>
</Page>
