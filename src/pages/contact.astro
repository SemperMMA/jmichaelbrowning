---
import Page from '@layouts/Page.astro';
import { SITE } from '@lib/site';
---
<Page
  title="If the mission is real, I want to hear about it."
  eyebrow="Contact · let's talk"
  lede="The fastest path to a real conversation is a short, specific email — what you're trying to ship, by when, and what's currently in the way."
>
  <section class="section">
    <div class="wrap">
      <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 80px;">
        <div class="reveal">
          <h2 class="headline mb-md">Send a brief.</h2>
          <p class="text-mute mb-md">For Cloudflare Pages, wire this form to a Worker route, Pages Function, or third-party endpoint (e.g. Formspree).</p>
          <a href={`mailto:${SITE.email}`} class="btn btn-primary">{SITE.email} →</a>
        </div>
        <aside class="reveal">
          <span class="mono">Best for</span>
          <ul style="list-style: none; padding: 0; margin: 12px 0 24px; color: var(--text-mute);">
            <li style="padding: 4px 0;">— Modernization & strategy engagements</li>
            <li style="padding: 4px 0;">— Standing communications operations</li>
            <li style="padding: 4px 0;">— Executive briefings & advisory</li>
          </ul>
        </aside>
      </div>
    </div>
  </section>
</Page>
