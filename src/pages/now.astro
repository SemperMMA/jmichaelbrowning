---
// src/pages/now.astro
// export const prerender = true;  — uncomment once content is stable
import Page from '../layouts/Page.astro';
import { getEmDashCollection } from 'emdash';

const { entries: nowItems } = await getEmDashCollection('now', {
  orderBy: [{ field: 'sort_order', direction: 'asc' }],
  filter: { status: 'published' },
});

const updatedStr = new Date().toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: 'numeric' });
---
<Page
  title="What I'm doing this season."
  eyebrow={`/ now · updated ${updatedStr}`}
  lede="A snapshot of where my attention is. Honest, current, occasionally outdated. Updated roughly monthly."
>
  <section class="section" data-screen-label="08 Now">
    <div class="wrap-narrow">
      <div class="reveal-stagger">
        {nowItems.length > 0 ? nowItems.map(item => (
          <div style="padding: 28px 0; border-bottom: 1px solid var(--hairline);">
            <span class="mono">{item.data.label}</span>
            <h3 class="title" style="margin: 14px 0 12px;">{item.data.title}</h3>
            <div class="text-mute" set:html={item.data.body ?? item.data.description ?? ''} />
          </div>
        )) : (
          // Fallback static content when DB is empty
          <>
            <div style="padding: 28px 0; border-bottom: 1px solid var(--hairline);">
              <span class="mono">Working on</span>
              <h3 class="title" style="margin: 14px 0 12px;">Two engagements, one quiet research thread.</h3>
              <p class="text-mute">A federal modernization roadmap (year two), a standing comms operation for a national nonprofit, and long-running research on coordination failure inside large organizations.</p>
            </div>
            <div style="padding: 28px 0; border-bottom: 1px solid var(--hairline);">
              <span class="mono">Writing</span>
              <h3 class="title" style="margin: 14px 0 12px;">A long essay on durability.</h3>
              <p class="text-mute">Working title: <em>What survives the next administration.</em></p>
            </div>
            <div style="padding: 28px 0;">
              <span class="mono">Not doing</span>
              <h3 class="title" style="margin: 14px 0 12px;">New advisory roles. New podcast appearances.</h3>
              <p class="text-mute">Both will return. For now, the focus is on the engagements I'm in.</p>
            </div>
          </>
        )}
      </div>
      <div class="text-center mt-lg reveal">
        <p class="mono" style="color: var(--text-dim);">Inspired by <a href="https://nownownow.com" rel="noopener noreferrer" style="color: var(--text-mute); border-bottom: 1px solid var(--hairline);">nownownow.com</a></p>
      </div>
    </div>
  </section>
</Page>
