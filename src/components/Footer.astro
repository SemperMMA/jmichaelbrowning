---
import { SITE, NAV } from '@lib/site';
const year = new Date().getFullYear();
---
<footer id="site-footer" class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <h5>{SITE.domain}</h5>
        <p class="text-mute" style="max-width: 38ch; line-height: 1.55; font-size: 15px; margin: 0 0 18px;">
          A working archive of strategy, systems, and writing from {SITE.author}. Built deliberately. Shipped openly.
        </p>
        <a href={`mailto:${SITE.email}`} class="btn">Get in touch <span aria-hidden="true">→</span></a>
      </div>
      <div>
        <h5>Site</h5>
        <ul>
          {NAV.slice(0, 5).map(p => <li><a href={p.href}>{p.label}</a></li>)}
        </ul>
      </div>
      <div>
        <h5>More</h5>
        <ul>
          <li><a href="/notes">Notes</a></li>
          <li><a href="/speaking">Speaking</a></li>
          <li><a href="/uses">Uses</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <h5>Elsewhere</h5>
        <ul>
          <li><a href={SITE.social.linkedin}>LinkedIn ↗</a></li>
          <li><a href={SITE.social.github}>GitHub ↗</a></li>
          <li><a href={SITE.social.substack}>Substack ↗</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} {SITE.author} · All rights reserved</span>
      <span>v. 4.0</span>
    </div>
    <div class="footer-bottom" style="border-top:0; padding-top: 24px;">
      <span class="colossal">Browning.</span>
    </div>
  </div>
</footer>
