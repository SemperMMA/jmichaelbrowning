# Copy this to .env for local development
# These are NOT secrets — they configure local Wrangler proxying

SITE_URL="https://jmichaelbrowning.com"
EMDASH_ADMIN_EMAIL="hello@jmichaelbrowning.com"

# Set this to a strong random string for the first admin account password
# Only used during `pnpm bootstrap` — change it in the admin UI afterwards
EMDASH_ADMIN_PASSWORD="change-me-before-bootstrapping"
